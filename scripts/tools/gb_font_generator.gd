func _init() -> void:
	generate_font_sheet()
	quit()


func generate_font_sheet() -> void:
	var characters: Array[String] = _build_character_set()
	var rows := int(ceil(float(characters.size()) / float(COLUMNS)))
	var width := COLUMNS * GLYPH_SIZE
	var height := rows * GLYPH_SIZE

	var image := Image.create(width, height, false, Image.FORMAT_RGBA8)
	image.fill(BG_LIGHT)

	var map := {
		"glyph_size": GLYPH_SIZE,
		"columns": COLUMNS,
		"characters": {}
	}

	for index in range(characters.size()):
		var ch := characters[index]
		var cell_x := index % COLUMNS
		var cell_y := index / COLUMNS
		draw_glyph(image, ch, cell_x, cell_y)
		map["characters"][ch] = {"x": cell_x * GLYPH_SIZE, "y": cell_y * GLYPH_SIZE}

	_ensure_output_dir()
	var image_path := ProjectSettings.globalize_path(OUTPUT_IMAGE_PATH)
	var save_result := image.save_png(image_path)
	if save_result != OK:
		push_error("Failed to save font sheet: %s" % image_path)

	save_font_map(map)
	print("Generated font sheet: %s (%dx%d)" % [OUTPUT_IMAGE_PATH, width, height])
	print("Registered glyphs: %d" % characters.size())


func draw_glyph(image: Image, ch: String, cell_x: int, cell_y: int) -> void:
	var pattern: Array[String] = get_glyph_pattern(ch)
	var origin_x := cell_x * GLYPH_SIZE
	var origin_y := cell_y * GLYPH_SIZE
	for row in range(GLYPH_SIZE):
		var line: String = pattern[row]
		for col in range(GLYPH_SIZE):
			if line.substr(col, 1) == "1":
				image.set_pixel(origin_x + col, origin_y + row, DARK)
			elif ch == " ":
				image.set_pixel(origin_x + col, origin_y + row, BG_LIGHT)


func get_glyph_pattern(ch: String) -> Array[String]:
	if HIRAGANA_8X8.has(ch):
		return _typed_rows(HIRAGANA_8X8[ch])
	if KATAKANA_8X8.has(ch):
		return _typed_rows(KATAKANA_8X8[ch])
	if GLYPHS_8X8.has(ch):
		return _typed_rows(GLYPHS_8X8[ch])
	if GLYPHS_5X7.has(ch):
		return _expand_5x7(GLYPHS_5X7[ch])

	var lower := ch.to_lower()
	if GLYPHS_5X7.has(lower):
		return _expand_5x7(GLYPHS_5X7[lower])

	var upper := ch.to_upper()
	if GLYPHS_5X7.has(upper):
		return _expand_5x7(GLYPHS_5X7[upper])

	if GLYPHS_5X7.has("□"):
		return _expand_5x7(GLYPHS_5X7["□"])
	return _typed_rows(GLYPHS_8X8[" "])


func save_font_map(map: Dictionary) -> void:
	var path := ProjectSettings.globalize_path(OUTPUT_MAP_PATH)
	var file := FileAccess.open(path, FileAccess.WRITE)
	if file == null:
		push_error("Failed to open font map for writing: %s" % path)
		return
	file.store_string(JSON.stringify(map, "\t"))
	file.close()


func _ensure_output_dir() -> void:
	var absolute_dir := ProjectSettings.globalize_path("res://assets/fonts")
	DirAccess.make_dir_recursive_absolute(absolute_dir)


func _build_character_set() -> Array[String]:
	var seen := {}
	var result: Array[String] = []
	for source in REQUIRED_STRINGS:
		for i in range(source.length()):
			var ch: String = source.substr(i, 1)
			if ch == " ":
				if not seen.has(ch):
					seen[ch] = true
					result.append(ch)
				continue
			if not seen.has(ch):
				seen[ch] = true
				result.append(ch)
	return result


func _expand_5x7(rows_5x7: Array) -> Array[String]:
	var result: Array[String] = []
	result.append("00000000")
	for row in rows_5x7:
		result.append("0%s00" % String(row))
	return result


func _typed_rows(rows: Array) -> Array[String]:
	var result: Array[String] = []
	for row in rows:
		result.append(String(row))
	return result
